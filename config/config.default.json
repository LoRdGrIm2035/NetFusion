{
    "proxyPort":  8080,
    "dashboardPort":  9090,
    "dashboardAllowLAN": false,
    "blockQUICOnSecondaryAdapters": true,
    "mode":  "maxspeed",
    "startupTimeoutSec": 20,
    "monitorInterval":  2000,
    "healthCheck":  {
                        "pingTarget":  "8.8.8.8",
                        "pingTarget2":  "1.1.1.1",
                        "timeout":  1500,
                        "failThreshold":  3
                    },
    "proxy":  {
                  "connectTimeout":  7000,
                  "maxRetries":  3,
                  "bufferSize":  65536,
                  "minThreads":  96,
                  "maxThreads":  1024,
                  "jobTimeoutSec":  120,
                  "socketIoTimeout": 45000,
                  "listenerBacklog": 2048,
                  "staleJobTimeoutSec": 0,
                  "sessionAffinityTTL":  120,
                  "httpsBulkPromotionHostThreshold": 1,
                  "httpsBulkPromotionGlobalThreshold": 4,
                  "retryPolicy": "leastLoaded",
                  "retryWeightFloor": 0.25,
                  "bulkHeadroomWeight": 0.35,
                  "bulkPressureThreshold": 10,
                  "healthEndpoint":  true
              },
    "routing":  {
                    "targetMetric":  25,
                    "watchInterval":  15,
                    "ethernetPriority":  true,
                    "enforceECMP": true,
                    "metricRefreshSec": 30,
                    "ecmpRefreshSec": 60,
                    "splitRoutesEnabled":  false
                },
    "safety":  {
                   "watchdogInterval":  10,
                   "maxProxyRestarts":  3,
                   "cpuThresholdPercent":  15,
                   "memoryThresholdMB":  2000,
                   "circuitBreakerCooldownSec":  60,
                   "circuitBreaker": {
                       "proxyErrorRateThreshold": 0.15,
                       "consecutiveFailedPings": 5,
                       "memoryThresholdMB": 800,
                       "cpuThresholdPercent": 85,
                       "tripCooldownSeconds": 60
                   }
               },
    "selfHealing":  {
                         "enabled":  true,
                         "routeCheckInterval":  15,
                         "adapterRecoveryDelay":  5,
                         "dhcpAutoRepair": false,
                         "dhcpRepairIntervalSec": 120,
                         "dnsVerification":  true,
                         "gatewayChangeDetection":  true
                     },
    "intelligence":  {
                         "ewmaAlphas": {
                             "gaming": 0.65,
                             "streaming": 0.25,
                             "bulk": 0.15,
                             "interactive": 0.45,
                             "default": 0.30
                         },
                         "jitterWindow":  30,
                         "healthTrendWindow":  20,
                         "degradationThreshold":  -2.0,
                         "connectionTypeDetection":  true,
                         "adaptiveBuffers":  true,
                         "weightRefreshInterval":  2
                     },
    "learning":  {
                     "enabled":  true,
                     "dataFile":  "config/learning-data.json",
                     "maxEntries":  5000,
                     "decayFactor":  0.95,
                     "sessionInterval":  60,
                     "minSamplesForRecommendation":  20
                 },
    "trafficRules":  {
                         "downloadManagers":  {
                                                  "mode":  "maxspeed",
                                                  "apps":  [
                                                               "IDMan.exe",
                                                               "aria2c.exe",
                                                               "wget.exe",
                                                               "curl.exe"
                                                           ]
                                              },
                         "torrentClients":  {
                                                "mode":  "maxspeed",
                                                "apps":  [
                                                             "qbittorrent.exe",
                                                             "utorrent.exe",
                                                             "BitTorrent.exe",
                                                             "Deluge.exe"
                                                         ]
                                            },
                         "streaming":  {
                                           "mode":  "maxspeed",
                                           "apps":  [
                                                        "spotify.exe"
                                                    ]
                                       },
                         "gaming":  {
                                        "mode":  "maxspeed",
                                        "apps":  [
                                                     "steam.exe",
                                                     "EpicGamesLauncher.exe"
                                                 ]
                                    },
                         "browsers":  {
                                          "mode":  "maxspeed",
                                          "apps":  [
                                                       "chrome.exe",
                                                       "firefox.exe",
                                                       "msedge.exe",
                                                       "opera.exe",
                                                       "brave.exe"
                                                   ]
                                      }
                     },
    "telemetry":  {
                      "enabled":  true,
                      "decisionLogSize":  100,
                      "heatmapBuckets":  60
                  },
    "logging":  {
                    "level":  "info",
                    "maxCSVLines":  2000,
                    "maxEventEntries":  200
                },
    "profiles":  {
                     "maxspeed":  {
                                      "strategy":  "max-bandwidth",
                                      "description":  "Maximum speed -- all adapters pushed to full capacity with health-weighted distribution.",
                                      "ethernetBoost":  2.0
                                  },
                     "download":  {
                                      "strategy":  "bandwidth-weighted",
                                      "description":  "Maximize download throughput. Ethernet boosted 1.5x. Success-rate weighted.",
                                      "ethernetBoost":  1.5
                                  },
                     "streaming":  {
                                       "strategy":  "lowest-latency",
                                       "description":  "Prioritize lowest EWMA latency for smooth streaming. Stability-weighted.",
                                       "ethernetBoost":  2.0
                                   },
                     "gaming":  {
                                    "strategy":  "lowest-latency",
                                    "description":  "Ultra-low latency for gaming. Jitter-penalized. Ethernet boosted 3x.",
                                    "ethernetBoost":  3.0
                                },
                     "balanced":  {
                                      "strategy":  "round-robin",
                                      "description":  "Equal distribution across all healthy interfaces.",
                                      "ethernetBoost":  1.0
                                  }
                 },
    "excludedAdapters":  [

                         ],
    "autoStart":  false
}

